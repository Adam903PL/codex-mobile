DJANGO_DEBUG=1
DJANGO_SECRET_KEY=devlink-local-secret-change-me-minimum-32-characters
# Local dev can omit these. With DJANGO_DEBUG=1 DevLink accepts LAN hosts and Expo origins.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.9
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://192.168.0.9:8081
DB_ENGINE=django.db.backends.postgresql
DB_NAME=devlink
DB_USER=devlink
DB_PASSWORD=devlink_password
DB_HOST=127.0.0.1
DB_PORT=54329
CHANNEL_REDIS_URL=redis://127.0.0.1:63799/0
# Local dev uses in-memory Channels by default. Set this only when you run Redis.
# CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer
